<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trader Portfolio</title>
    <style>
        body { background-color: #121212; color: white; font-family: sans-serif; text-align: center; margin: 0; padding: 0; }
        nav { padding: 20px; background: #1e1e1e; }
        .logo { height: 60px; filter: drop-shadow(0 0 10px purple); }
        .profile-img { width: 200px; height: 200px; border-radius: 50%; border: 3px solid #ffc107; object-fit: cover; margin-top: 20px; }
        .container { padding: 40px 10%; }
        .card { background: #1e1e1e; margin-bottom: 20px; padding: 20px; border-radius: 10px; }
        .card img { width: 100%; max-width: 500px; border-radius: 10px; }
        h1 { color: #ffc107; }
    </style>
</head>
<body>

    <nav>
        <img src="logo.jpg" alt="Logo" class="logo">
    </nav>

    <div class="container">
        <img src="wajah.jpg" alt="Wajah" class="profile-img">
        <h1>Professional Trader Trainer</h1>
        <p>Disiplin, Data, dan Mindset.</p>

        <div class="card">
            <h3>Trading Setup</h3>
            <img src="keahlian.jpg" alt="Setup">
        </div>

        <div class="card">
            <h3>Analisis & Fokus</h3>
            <img src="keahlian%20anlisia.jpg" alt="Analisis">
        </div>
    </div>

    <footer style="padding: 20px; color: #555;">&copy; 2026 Portofolio Jeks</footer>

</body>
</html>
